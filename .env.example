# Skill Library — environment variables for the import scripts
# Copy this file to `.env` (gitignored) and fill in your values.

# Supabase project URL
# Find at: Supabase Dashboard → Project Settings → API
SUPA_URL=https://your-project-ref.supabase.co

# service_role key (bypasses RLS) — KEEP SECRET, never commit
# Find at: Supabase Dashboard → Project Settings → API → service_role
SUPA_SERVICE_KEY=eyJhbGc...

# Local path to skills directory (used by scripts/import-skills.mjs)
SKILLS_DIR=/path/to/your/skills

# Optional — used by scripts/add-insta.mjs and scripts/add-custom.mjs
INSTA_SKILL_PATH=/path/to/INSTAGRAM_OPERATOR_PROMPT.md
LINKEDIN_SKILL_PATH=/path/to/linkedin-skill/SKILL.md
