{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/skill/:id", "destination": "/api/skill/:id" },
    { "source": "/s/:id", "destination": "/api/skill/:id" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/:path*.(js|css|png|jpg|jpeg|svg|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
